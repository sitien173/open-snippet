{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openmacro",
  "version": "0.1.0",
  "identifier": "dev.openmacro",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "openmacro Settings",
        "width": 900,
        "height": 640,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "openmacro",
    "shortDescription": "Snippet expander",
    "longDescription": "OpenMacro is a desktop snippet expander for Windows with local snippet storage, form prompts, shell snippets, and optional git-backed sync.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
